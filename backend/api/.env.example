NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:pass@localhost:5432/sne
USE_REDIS=true
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace_with_64_char_secret
JWT_REFRESH_SECRET=replace_with_64_char_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
FRONTEND_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_API=200
RATE_LIMIT_MAX_LOGIN=10
RATE_LIMIT_MAX_PUBLIC=20
RESEND_API_KEY=
EMAIL_FROM=no-reply@sne.vn
NEXTJS_REVALIDATE_URL=
NEXTJS_REVALIDATE_SECRET=
SETTINGS_CACHE_PREFIX=settings
